-- ====================================================================
-- ระบบที่ 1: Player Modifiers (กันตกไต่กำแพง + สลับวิ่งเร็ว 20 / 25 ตอนเจอ Seek)
-- ====================================================================
local function setupPlayerMods(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not hrp or not humanoid then return end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude

    -- [ สร้าง BodyVelocity ควบคุมการเดินและกันตก ]
    local moveBv = Instance.new("BodyVelocity")
    moveBv.Name = "MovementBV"
    moveBv.MaxForce = Vector3.new(0, 0, 0)
    moveBv.Velocity = Vector3.new(0, 0, 0)
    moveBv.Parent = hrp

    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not char or not char.Parent or humanoid.Health <= 0 then
            connection:Disconnect()
            return
        end

        -- ตรวจสอบว่าเจอ SeekMovingNewClone ใน Workspace หรือไม่
        local isSeekPresent = Workspace:FindFirstChild("SeekMovingNewClone") ~= nil
        
        -- ถ้าเจอ Seek วิ่ง 25, ถ้าไม่เจอวิ่งความเร็วปกติ 20
        local currentSpeed = isSeekPresent and 25 or 20

        -- 1. ยิงเลเซอร์ตรวจหาพื้นด้านล่าง (ระยะ 50 studs)
        local downRay = Workspace:Raycast(hrp.Position, Vector3.new(0, -50, 0), raycastParams)
        local targetVel = humanoid.MoveDirection * currentSpeed

        if not downRay then
            -- ============================================
            -- [ โหมดกันตก ] เมื่อทะลุแมพหรือร่วงลงเหว
            -- ============================================
            local yVel = 0
            
            -- ยิงเลเซอร์รอบตัวเช็คว่าเดินชนกำแพงหรือไม่
            if humanoid.MoveDirection.Magnitude > 0 then
                local wallRay = Workspace:Raycast(hrp.Position, humanoid.MoveDirection * 2.5, raycastParams)
                if wallRay then
                    -- ถ้าเดินชนกำแพง/ขอบแมพ ให้ลอยขึ้นฟ้าอัตโนมัติ
                    yVel = currentSpeed
                end
            end
            
            -- ล็อคตัวละครไม่ให้ร่วงลงเหว + ดันขึ้นเมื่อชนกำแพง
            moveBv.MaxForce = Vector3.new(100000, 100000, 100000)
            moveBv.Velocity = Vector3.new(targetVel.X, yVel, targetVel.Z)
        else
            -- ============================================
            -- [ โหมดเดินปกติ ] เมื่ออยู่บนพื้น
            -- ============================================
            if humanoid.MoveDirection.Magnitude > 0 then
                moveBv.MaxForce = Vector3.new(100000, 0, 100000)
                moveBv.Velocity = targetVel
            else
                moveBv.MaxForce = Vector3.new(0, 0, 0)
                moveBv.Velocity = Vector3.new(0, 0, 0)
            end
        end
    end)
end

if LocalPlayer.Character then
    setupPlayerMods(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(setupPlayerMods)


