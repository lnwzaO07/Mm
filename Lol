local FONT_STYLE   = 3                             -- Enum.Font.Monospace
local FONT_SIZE    = 14                            -- ขนาดปกติทั่วไป

local currentDoorTarget = nil
local latestRoomNum = -1       
local targetRoomNum = -1       

local activeKeys = {}
local activeLevers = {}
local activeBooks = {}
local activePapers = {}
local activeEnemies = {}
local activeFuses = {}
