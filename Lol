-- ====================================================================
-- ระบบที่ 1: Auto Anti-Fall (ป้องกันการตกแมพ)
-- ====================================================================
local function setupAutoAntiFall(char)
    -- รอให้ชิ้นส่วนหลักของตัวละครโหลดเสร็จ
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not hrp or not humanoid then return end

    -- สร้าง BodyVelocity เตรียมไว้ในตัวละคร (แต่ปิดการทำงานไว้ก่อน)
    local bv = Instance.new("BodyVelocity")
    bv.Name = "AutoAntiFallBV"
    bv.MaxForce = Vector3.new(0, 0, 0) -- ค่า 0 หมายถึงยังไม่ทำงาน
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = hrp

    -- ตั้งค่า Raycast (เพื่อไม่ให้เส้น Raycast ไปชนกับตัวละครของเราเอง)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude

    -- ลูปตรวจสอบพื้นตลอดเวลา
    local connection
    connection = RunService.Heartbeat:Connect(function()
        -- หากตัวละครตายหรือถูกลบ ให้ยกเลิกลูปนี้
        if not char or not char.Parent or humanoid.Health <= 0 then
            connection:Disconnect()
            return
        end

        -- ยิง Raycast จากกลางลำตัว ลงไปด้านล่าง 15 studs
        local rayDirection = Vector3.new(0, -15, 0)
        local rayResult = Workspace:Raycast(hrp.Position, rayDirection, raycastParams)

        if not rayResult then
            -- ถ้า Raycast ไม่ชนอะไรเลย (ไม่มีพื้นในระยะ 15 studs) -> เปิดใช้งาน Anti-Fall
            bv.MaxForce = Vector3.new(0, math.huge, 0)
            
            -- ยกเลิกแรงตกกระแทก
            local currentVel = hrp.AssemblyLinearVelocity
            hrp.AssemblyLinearVelocity = Vector3.new(currentVel.X, 0, currentVel.Z)
        else
            -- ถ้าเจอพื้น -> ปิดใช้งาน Anti-Fall ให้ตกหรือเดินตามปกติ
            bv.MaxForce = Vector3.new(0, 0, 0)
        end
    end)
end

-- เรียกใช้ฟังก์ชันทันทีหากมีตัวละครอยู่แล้ว
if LocalPlayer.Character then
    setupAutoAntiFall(LocalPlayer.Character)
end

-- ตรวจจับเมื่อตัวละครตายและเกิดใหม่ ให้ระบบทำงานต่อเนื่อง
LocalPlayer.CharacterAdded:Connect(setupAutoAntiFall)


